# =============================================================================
# free-tier-showcase — environment variables
# =============================================================================
# This is a static-friendly Next.js site. The only env var the build cares
# about is the base URL (used in metadata / canonical tags).
# Copy this to .env.local and fill in.
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Free Tier Showcase"

# Optional — pick ONE privacy-friendly analytics provider for the showcase
# itself. Cloudflare Web Analytics needs no env var (just the script tag);
# Plausible needs the domain.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-deployed-domain.com
